generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  coverImage  String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  photos      Photo[]
}

model Photo {
  id          String   @id @default(uuid())
  url         String
  title       String?
  description String?
  publicId    String?
  alt         String?
  order       Int      @default(0)
  isActive   Boolean  @default(true)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
}

model SiteContent {
  id    String @id @default(uuid())
  key   String @unique
  value Json
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
}

enum LeadStatus {
  NEW
  READ
  CONTACTED
  CLOSED
}

model Booking {
  id        String   @id @default(uuid())
  name      String
  email     String
  date      DateTime
  status    BookingStatus @default(PENDING)
  createdAt DateTime @default(now())
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Finance {
  id        String   @id @default(uuid())
  amount    Float
  concept   String
  status    FinanceStatus @default(PENDING)
  createdAt DateTime @default(now())
}

enum FinanceStatus {
  PENDING
  PAID
}

model Plan {
  id          String @id @default(uuid())
  name        String
  description String?
  price       Float
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value Json
}
